{
  "name": "kanvas",
  "displayName": "Kanvas",
  "description": "A hand-drawn style diagram/sketch editor for .kanvas files.",
  "version": "0.1.12",
  "publisher": "Phenomenal1",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brijesh-0106/Kanvas-VS-Code-Extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kanvas",
        "aliases": [
          "Kanvas Drawing"
        ],
        "extensions": [
          ".kanvas"
        ],
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "kanvas.canvas",
        "displayName": "Kanvas Canvas",
        "icon": "icon.png",
        "selector": [
          {
            "filenamePattern": "*.kanvas"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "kanvas.exportPng",
        "title": "Kanvas: Export as PNG"
      },
      {
        "command": "kanvas.exportSvg",
        "title": "Kanvas: Export as SVG"
      },
      {
        "command": "kanvas.new",
        "title": "Kanvas: New Kanvas File"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "kanvas.exportPng"
        },
        {
          "command": "kanvas.exportSvg"
        },
        {
          "command": "kanvas.new"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "roughjs": "^4.6.6"
  }
}